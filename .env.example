# System Configuration
PORT=8000
HOST=0.0.0.0

# API Security (Incoming Webhook Authentication)
# Set a strong key here. In Webhook requests, pass this in the header: X-API-KEY: your-secure-api-key
API_KEY=your-secure-api-key-here

# Database Configuration
# Options: sqlite, postgres, sheets
DATABASE_TYPE=sqlite

# SQLite Config (only used if DATABASE_TYPE=sqlite)
SQLITE_DB_PATH=trades.db

# PostgreSQL Config (only used if DATABASE_TYPE=postgres)
# Example: postgresql://postgres:password@localhost:5432/trading_journal
DATABASE_URL=postgresql://user:password@localhost:5432/trading_journal

# Google Sheets Config (only used if DATABASE_TYPE=sheets)
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id-here
# Path to service_account.json OR raw JSON string of the credentials
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=service_account.json

# Notification Integrations (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Discord Bot Listener Configuration
# Create a NEW Discord Application at https://discord.com/developers
# Enable "Message Content Intent" under Bot > Privileged Gateway Intents
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# A+ Setups Channel (full 1R risk trades)
DISCORD_APLUS_CHANNEL_ID=your-a-plus-channel-id

# Half Risk / 0.25R Setups Channel
DISCORD_HALFRISK_CHANNEL_ID=your-half-risk-channel-id

